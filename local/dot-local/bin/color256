#!/usr/bin/env bash
set -euo pipefail

script_path="$(readlink -f -- "${BASH_SOURCE[0]}")"
repo_root="$(cd -- "$(dirname -- "$script_path")/../../.." && pwd)"

DISPATCH_PACKAGED_TOOL_CALLER="$script_path" \
  exec "$repo_root/local/dot-local/lib/tools/dispatch-packaged-tool" \
  color256 python3 "$repo_root/tools/thememanager/src/color256/color256.py" -- "$@"
