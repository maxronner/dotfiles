#!/usr/bin/env bash
set -euo pipefail

THEME_DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/theme"
PALETTE_FILE="${THEME_DATA_DIR}/palette.json"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}"
THEME_LOCK="${XDG_RUNTIME_DIR:-/tmp}/theme.${UID}.lock"

# Palette Reload adapter contract:
# - An adapter is an executable file at $XDG_CONFIG_HOME/<app>/scripts/apply-theme.
# - With no args, the adapter applies the current Palette Artifact.
# - With --check, the adapter validates its prerequisites and exits non-zero on failure.
# - Adapter stdout is ignored; stderr is reserved for human-readable diagnostics.

check=0
if [[ "${1:-}" == "--check" ]]; then
  check=1
fi

if [[ ! -f "$PALETTE_FILE" ]]; then
  echo "theme-apply-all: no palette at $PALETTE_FILE, skipping" >&2
  exit 0
fi

# Acquire lock (non-blocking — exit if already held)
# THEME_LOCK_HELD=1 means the caller (e.g. thememanager) already holds the lock.
if [[ "${THEME_LOCK_HELD:-}" != "1" ]]; then
  exec 9>"$THEME_LOCK"
  flock -n 9 || { echo "theme-apply-all: already running" >&2; exit 0; }
fi

applied=0
failed=0
pids=()
pid_app=()

arg=""
(( check )) && arg="--check"

discover_adapters() {
  local script
  shopt -s nullglob
  for script in "$CONFIG_DIR"/*/scripts/apply-theme; do
    [[ -x "$script" ]] || continue
    printf '%s\n' "$script"
  done | sort
  shopt -u nullglob
}

while IFS= read -r script; do
  [[ -x "$script" ]] || continue
  app="${script#"$CONFIG_DIR"/}"
  app="${app%%/*}"
  "$script" $arg &
  pids+=($!)
  pid_app+=("$app")
done < <(discover_adapters)

for i in "${!pids[@]}"; do
  if wait "${pids[$i]}"; then
    applied=$((applied + 1))
  else
    echo "theme-apply-all: FAIL ${pid_app[$i]}" >&2
    failed=$((failed + 1))
  fi
done

echo "theme-apply-all: applied=$applied failed=$failed" >&2

if (( failed )); then
  exit 1
fi
