#!/usr/bin/env bash
set -euo pipefail

THEME_DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/theme"
PALETTE_FILE="${THEME_DATA_DIR}/palette.json"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}"
THEME_LOCK="${XDG_RUNTIME_DIR:-/tmp}/theme.${UID}.lock"

check=0
if [[ "${1:-}" == "--check" ]]; then
  check=1
fi

if [[ ! -f "$PALETTE_FILE" ]]; then
  echo "theme-apply-all: no palette at $PALETTE_FILE, skipping" >&2
  exit 0
fi

# Acquire lock (non-blocking — exit if already held)
# THEME_LOCK_HELD=1 means the caller (e.g. thememanager) already holds the lock.
if [[ "${THEME_LOCK_HELD:-}" != "1" ]]; then
  exec 9>"$THEME_LOCK"
  flock -n 9 || { echo "theme-apply-all: already running" >&2; exit 0; }
fi

applied=0
failed=0
pids=()
pid_app=()

arg=""
(( check )) && arg="--check"

for script in "$CONFIG_DIR"/*/scripts/apply-theme; do
  [[ -x "$script" ]] || continue
  app="${script#"$CONFIG_DIR"/}"
  app="${app%%/*}"
  "$script" $arg &
  pids+=($!)
  pid_app+=("$app")
done

for i in "${!pids[@]}"; do
  if wait "${pids[$i]}"; then
    applied=$((applied + 1))
  else
    echo "theme-apply-all: FAIL ${pid_app[$i]}" >&2
    failed=$((failed + 1))
  fi
done

echo "theme-apply-all: applied=$applied failed=$failed" >&2

if (( failed )); then
  exit 1
fi
