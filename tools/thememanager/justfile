build_dir := env_var_or_default("THEMEMANAGER_BUILD_DIR", "/tmp/thememanager-dist")

test:
    python3 tests/test_thememanager.py

build:
    #!/usr/bin/env bash
    set -euo pipefail
    out_dir="{{build_dir}}"
    cleanup() {
        rm -rf build src/thememanager.egg-info src/__pycache__ src/color256/__pycache__
    }
    trap cleanup EXIT
    rm -rf "$out_dir"
    mkdir -p "$out_dir"
    if command -v uv >/dev/null 2>&1; then
        uv build . --out-dir "$out_dir"
    elif python3 -m build --version >/dev/null 2>&1; then
        python3 -m build . --outdir "$out_dir"
    else
        echo "Missing uv or python build module." >&2
        exit 1
    fi
    compgen -G "$out_dir/thememanager-*.whl" >/dev/null
    compgen -G "$out_dir/thememanager-*.tar.gz" >/dev/null

ci:
    just test
    just build
