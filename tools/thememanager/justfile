build_dir := env_var_or_default("THEMEMANAGER_BUILD_DIR", "/tmp/thememanager-dist")

test:
    python3 tests/test_thememanager.py

build:
    #!/usr/bin/env bash
    set -euo pipefail
    out_dir="{{build_dir}}"
    cleanup() {
        rm -rf build src/thememanager.egg-info src/__pycache__ src/color256/__pycache__
    }
    trap cleanup EXIT
    rm -rf "$out_dir"
    mkdir -p "$out_dir"
    if command -v uv >/dev/null 2>&1; then
        uv build . --out-dir "$out_dir"
    elif python3 -m build --version >/dev/null 2>&1; then
        python3 -m build . --outdir "$out_dir"
    else
        echo "Missing uv or python build module." >&2
        exit 1
    fi
    compgen -G "$out_dir/thememanager-*.whl" >/dev/null
    compgen -G "$out_dir/thememanager-*.tar.gz" >/dev/null

ci:
    just test
    just build

check-release:
    #!/usr/bin/env bash
    set -euo pipefail
    version="$(sed -n 's/^version = "\(.*\)"$/\1/p' pyproject.toml | head -n 1)"
    if [[ -z "$version" ]]; then
        echo "Could not read version from pyproject.toml." >&2
        exit 1
    fi
    tag="v${version}"
    if git rev-parse -q --verify "refs/tags/${tag}" >/dev/null; then
        echo "Tag already exists: ${tag}" >&2
        exit 1
    fi
    just ci
    echo "Release check passed for ${tag}"

release:
    #!/usr/bin/env bash
    set -euo pipefail
    if [[ -n "$(git status --porcelain)" ]]; then
        echo "Working tree must be clean before release." >&2
        git status --short >&2
        exit 1
    fi
    version="$(sed -n 's/^version = "\(.*\)"$/\1/p' pyproject.toml | head -n 1)"
    tag="v${version}"
    just check-release
    git tag -s "$tag" -m "thememanager ${tag}"
    echo "Created ${tag}"
