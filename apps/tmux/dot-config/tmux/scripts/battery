#!/usr/bin/env bash

# Print battery segment for tmux status-right. No output if no battery is present.

bat=""
for p in /sys/class/power_supply/*; do
  [[ -e "$p/type" ]] || continue
  if [[ "$(<"$p/type")" == "Battery" ]]; then
    bat="$p"
    break
  fi
done

[[ -n "$bat" ]] || exit 0

{ read -r capacity <"$bat/capacity"; } 2>/dev/null || exit 0
{ read -r status <"$bat/status"; } 2>/dev/null || status=""

# sysfs can briefly report garbage or >100; bail out
[[ $capacity =~ ^[0-9]+$ ]] || exit 0
((capacity > 100 || capacity < 0)) && exit 0

printf -v capacity_fmt '%2d%%' "$capacity"

case $capacity in
[0-9] | 1[0-5]) color="colour1" ;;
1[6-9] | 2[0-9] | 30) color="colour3" ;;
*) color="colour30" ;;
esac

case $status in
Charging)
  icon="󰂄"
  color="colour2"
  ;;
Full) icon="󰁹" ;;
Discharging)
  if ((capacity < 31)); then
    icon="󰂃"
  else
    icon="󰁹"
  fi
  ;;
*) icon="󰂑" ;;
esac

out="#[fg=colour30]| "

if ((capacity < 31)) || [[ $status == Charging ]]; then
  out+="#[fg=$color]${capacity_fmt} $icon"
else
  out+="#[fg=colour30]${capacity_fmt} #[fg=$color]$icon"
fi

printf '%s\n' "$out"
