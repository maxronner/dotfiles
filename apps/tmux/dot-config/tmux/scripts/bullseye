#!/usr/bin/env bash
set -euo pipefail

marker="bullseye"
marker_set=0

cmd=()
session=""
current_dir=""
window_name=""

usage() {
  cat <<-EOF
Create or focus a named tmux window

Usage: $(basename "$0") [-m MARKER] -- COMMAND [ARGS...]

Options:
  -m, --marker MARKER    Window name to find/create (default: $marker)
  -h, --help             Show this help message and exit

Everything after '--' is treated as the COMMAND to run in the window.

e.g.:

  $(basename "$0") -m ai -- tgpt --chat --model gpt-4
EOF
}

parse_args() {
  while (($#)); do
    case "$1" in
    -m | --marker)
      marker=$2
      marker_set=1
      shift 2
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      echo "unknown option: $1" >&2
      exit 1
      ;;
    *) break ;;
    esac
  done

  ((${#@})) || {
    echo "missing command" >&2
    exit 1
  }

  cmd=("$@")
  window_name="$marker"
  ((marker_set)) || window_name="$1"
}

main() {
  parse_args "$@"

  session=$(tmux display -p '#S')
  current_dir=$(tmux display -p -F '#{pane_current_path}')

  tmux select-window -t "$session:$window_name" 2>/dev/null ||
    tmux new-window -n "$window_name" -c "$current_dir" "${cmd[@]}"
}

main "$@"
