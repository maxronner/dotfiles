#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<EOF
usage:
  $0 [-n NAME] [--cwd DIR] [--force] [DIR] -- [cmd [args...]]
EOF
  exit 1
}

session_name=""
cwd=""
force=0
cmd=()
has_double_dash=0

# First pass: check if -- is present
for arg in "$@"; do
  if [[ "$arg" == "--" ]]; then
    has_double_dash=1
    break
  fi
done

while (($#)); do
  case "$1" in
  -n | --name)
    [[ $# -ge 2 ]] || usage
    session_name=$2
    shift 2
    ;;
  --cwd)
    [[ $# -ge 2 ]] || usage
    cwd=$2
    shift 2
    ;;
  -f | --force)
    force=1
    shift
    ;;
  --)
    shift
    cmd=("$@")
    break
    ;;
  -*)
    usage
    ;;
  *)
    if ((has_double_dash)); then
      # With --, positional arg is cwd
      [[ -z $cwd ]] || usage
      cwd=$1
    else
      # Without --, positional arg is session name
      [[ -z $session_name ]] || usage
      session_name=$1
    fi
    shift
    ;;
  esac
done

# Default cwd to $HOME if not set
[[ -n $cwd ]] || cwd="$HOME"

if [[ -z $session_name ]]; then
  if ((${#cmd[@]})); then
    session_name=$(basename "${cmd[0]}")
  else
    session_name=$(basename "$PWD")
  fi
fi

if ((force)) && tmux has-session -t "$session_name" 2>/dev/null; then
  tmux kill-session -t "$session_name"
fi

if ! tmux has-session -t "$session_name" 2>/dev/null; then
  if ((${#cmd[@]})); then
    tmux new-session -d -s "$session_name" -c "$cwd" "${cmd[@]}"
  else
    tmux new-session -d -s "$session_name" -c "$cwd"
  fi
fi

if [[ -n ${TMUX-} ]]; then
  tmux switch-client -t "$session_name"
else
  tmux attach-session -t "$session_name"
fi
