#!/usr/bin/env bash

session_path_key() {
  local session_name="$1"

  SESSION_NAME="$session_name" python3 - <<'PY'
import os
from urllib.parse import quote

print(quote(os.environ["SESSION_NAME"], safe="._-"))
PY
}

session_name=$(tmux display-message -p '#S' 2>/dev/null)
session_id=$(tmux display-message -p '#{session_id}' 2>/dev/null)

if [ -z "$session_name" ]; then
  nvim "$@"
  exit $?
fi

nvim_socket_dir="${XDG_RUNTIME_DIR:-/tmp}/nvim-sockets"
mkdir -pm 700 "$nvim_socket_dir"

nvim_socket_key=${session_id#\$}

if [[ -z "$nvim_socket_key" ]]; then
  nvim_socket_key="$(session_path_key "$session_name")"
fi

nvim_listen_addr="$nvim_socket_dir/nvim-$nvim_socket_key.sock"

if [[ -S "$nvim_listen_addr" ]]; then
  if nvim --server "$nvim_listen_addr" --headless --remote-expr "1" >/dev/null 2>&1; then
    nvim_window_index=""
    nvim_pane_index=""
    while IFS=' ' read -r nvim_window_index nvim_pane_index; do
      break
    done < <(
      tmux list-panes -t "$session_name" \
        -F '#{window_index} #{pane_index} #{pane_current_command}' 2>/dev/null |
        awk '$3 == "nvim" {print $1, $2; exit}'
    )

    if [[ -n "$nvim_window_index" && -n "$nvim_pane_index" ]]; then
      tmux select-window -t "${session_name}:${nvim_window_index}" >/dev/null 2>&1 || true
      tmux select-pane -t "${session_name}:${nvim_window_index}.${nvim_pane_index}"
      exit 0
    fi
  else
    rm -f "$nvim_listen_addr"
  fi
fi

if [[ -t 0 ]]; then
  exec nvim --listen "$nvim_listen_addr" "$@"
else
  tmux new-window -n nvim -c "#{pane_current_path}" -- nvim --listen "$nvim_listen_addr" "$@"
fi
