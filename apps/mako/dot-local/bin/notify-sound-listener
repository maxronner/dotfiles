#!/usr/bin/env bash

set -u

lock_file=/tmp/notification_lock
cooldown=1
sound=/usr/share/sounds/freedesktop/stereo/message.oga

dbus-monitor "interface='org.freedesktop.Notifications'" |
  while IFS= read -r line; do
    [[ $line == *"method call"*Notify* ]] || continue

    if (
      set -o noclobber
      : >"$lock_file"
    ) 2>/dev/null; then
      (
        paplay "$sound"
        sleep "$cooldown"
        rm -f -- "$lock_file"
      ) &
    fi
  done
