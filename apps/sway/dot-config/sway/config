# Read `man 5 sway` for a complete reference.
include $HOME/.config/sway/theme.config

set $font "pango:Jetbrains Mono Nerd Font"
font $font 12

### Variables
#
set $scripts $HOME/.config/sway/scripts

# Logo key. Use Mod1 for Alt.
set $mod Mod4

## Cursor
set $cursor "BreezeX-RosePine-Linux"
set $cursor_normal "28"
set $cursor_big "46"
set $cursor_hide_timeout "2000"
seat * xcursor_theme $cursor $cursor_normal
seat * hide_cursor $cursor_hide_timeout

## Home row direction keys
set $left h
set $down j
set $up k
set $right l

## Your preferred application launcher
# Note: pass the final command to swaymsg so that the resulting window can be opened
# on the original workspace that the command was run on.
set $menu tofi-drun | xargs -r swaymsg exec --

## Apps
set $term ghostty
set $browser zen-browser
set $tmux $term --title=terminal -e zsh -lic tmux-launcher
set $lock swaylock -f -e \
    -i $HOME/.config/sway/lock.wallpaper \
    --hide-keyboard-layout

include /etc/sway/config-vars.d/*

default_border pixel 2
gaps inner 10
gaps outer 10
# remove gaps when only one window is present
smart_gaps on
# remove outer gaps when only one workspace exists on output
smart_borders on

# Application rules
for_window [app_id="pavucontrol"] floating enable
for_window [class="Godot"] floating enable
for_window [app_id="$home_app"] floating enable, resize set 1500 900
for_window [title="^btop-float$"] floating enable, resize set 1300 800
for_window [title="^tv-float$"] floating enable, resize set 1300 800
for_window [title="^pulsemixer-float$"] floating enable, resize set 1600 900

for_window [app_id=".*"] inhibit_idle fullscreen
for_window [class=".*"] inhibit_idle fullscreen
for_window [app_id="gamemoderun"] inhibit_idle open
for_window [app_id="gamescope"] inhibit_idle open

assign [title="^terminal$"] workspace 1
assign [app_id="zen"] workspace 2
assign [app_id="vesktop"] workspace 3
assign [class="steam"] workspace 4
assign [app_id="net.lutris.Lutris"] workspace 4
assign [app_id="gamemoderun"] workspace 4
assign [app_id="gamescope"]  workspace 4


### Idle configuration
#
#
#
exec swayidle -w \
    timeout 300 '$lock' \
    timeout 420 'swaymsg "output * dpms off"' \
    resume 'swaymsg "output * dpms on"' \
    timeout 600 'systemctl suspend' \
    before-sleep 'playerctl pause; $lock' \
    after-resume 'swaymsg "seat * hide_cursor $cursor_hide_timeout"'

### Input configuration
#
# You can get the names of your inputs by running: swaymsg -t get_inputs
# Read `man 5 sway-input` for more information about this section.
#
input "type:keyboard" {
	xkb_layout "se,us"
}

input "type:pointer" {
	accel_profile "flat"
	pointer_accel 0
}

input "type:touchpad" {
	dwt enabled
	tap enabled
	middle_emulation enabled
    natural_scroll enabled
}

### Key bindings
#
# Basics:
#
    bindsym $mod+t exec $tmux
    bindsym $mod+Shift+t exec $term

    bindsym $mod+Shift+q kill

    bindsym $mod+d exec $menu
    bindsym $mod+u exec $browser
    bindsym $mod+g exec gammastep-toggle.sh
    bindsym $mod+Shift+w exec $lock

    bindsym $mod+c exec hyprpicker --autocopy

    bindsym $mod+Shift+d exec dict
    bindsym $mod+Shift+Escape exec $scripts/scratch-toggle.sh -t btop-float -- foot --title=btop-float -e btop
    bindsym $mod+p exec $scripts/toggle-pulsemixer.sh
    bindsym $mod+i exec foot --title=tv-float -e zsh -ic 'tv channels'

    # bindsym $mod+p exec pgrep -x pavucontrol >/dev/null && pkill -x pavucontrol || pavucontrol

    bindsym $mod+Shift+Print exec $scripts/screenshot.sh selection
    bindsym $mod+Print exec $scripts/screenshot.sh focused
    bindsym Print exec $scripts/screenshot.sh full

    # Drag floating windows by holding down $mod and left mouse button.
    # Resize them with right mouse button + $mod.
    # Despite the name, also works for non-floating windows.
    # Change normal to inverse to use left mouse button for resizing and right
    # mouse button for dragging.
    floating_modifier $mod normal

    # Reload the configuration file
    bindsym $mod+Shift+c reload

    # Reload waybar
    bindsym $mod+Shift+x exec pkill -SIGUSR2 waybar
    bindsym $mod+x exec $scripts/toggle-waybar.sh

#
# Appearance:
#
    bindsym $mod+o exec $scripts/select-wallpaper.sh
    bindsym $mod+Shift+o exec $scripts/select-theme.sh

    bindsym $mod+Shift+r exec systemctl --user restart swaybg-update.service

    bindsym $mod+z exec $scripts/toggle-cursor-hide.sh $cursor_hide_timeout
    bindsym $mod+Shift+z exec $scripts/toggle-cursor-size.sh $cursor $cursor_normal $cursor_big

#
# Moving around:
#
    # Move your focus around
    bindsym $mod+$left focus left
    bindsym $mod+$down focus down
    bindsym $mod+$up focus up
    bindsym $mod+$right focus right
    # Or use $mod+[up|down|left|right]
    bindsym $mod+Left focus left
    bindsym $mod+Down focus down
    bindsym $mod+Up focus up
    bindsym $mod+Right focus right

    # Move the focused window with the same, but add Shift
    bindsym $mod+Shift+$left move left
    bindsym $mod+Shift+$down move down
    bindsym $mod+Shift+$up move up
    bindsym $mod+Shift+$right move right
    # Ditto, with arrow keys
    bindsym $mod+Shift+Left move left
    bindsym $mod+Shift+Down move down
    bindsym $mod+Shift+Up move up
    bindsym $mod+Shift+Right move right
#
# Workspaces:
#
    # Switch to workspace
    bindsym $mod+1 workspace number 1
    bindsym $mod+2 workspace number 2
    bindsym $mod+3 workspace number 3
    bindsym $mod+4 workspace number 4
    bindsym $mod+5 workspace number 5
    bindsym $mod+6 workspace number 6
    bindsym $mod+7 workspace number 7
    bindsym $mod+8 workspace number 8
    bindsym $mod+9 workspace number 9
    bindsym $mod+0 workspace number 10
    # Move focused container to workspace
    bindsym $mod+Shift+1 move container to workspace number 1
    bindsym $mod+Shift+2 move container to workspace number 2
    bindsym $mod+Shift+3 move container to workspace number 3
    bindsym $mod+Shift+4 move container to workspace number 4
    bindsym $mod+Shift+5 move container to workspace number 5
    bindsym $mod+Shift+6 move container to workspace number 6
    bindsym $mod+Shift+7 move container to workspace number 7
    bindsym $mod+Shift+8 move container to workspace number 8
    bindsym $mod+Shift+9 move container to workspace number 9
    bindsym $mod+Shift+0 move container to workspace number 10
    # Note: workspaces can have any name you want, not just numbers.
    # We just use 1-10 as the default.
#
# Layout stuff:
#
    # You can "split" the current object of your focus with
    # $mod+b or $mod+v, for horizontal and vertical splits
    # respectively.
    bindsym $mod+b splith
    bindsym $mod+v splitv

    # Switch the current container between different layout styles
    bindsym $mod+s layout stacking
    bindsym $mod+w layout tabbed
    bindsym $mod+e layout toggle split

    # Make the current focus fullscreen
    bindsym $mod+f fullscreen

    # Toggle the current focus between tiling and floating mode
    bindsym $mod+Shift+space floating toggle

    # Swap focus between the tiling area and the floating area
    bindsym $mod+space focus mode_toggle

    # Move focus to the parent container
    bindsym $mod+a focus parent
#
# Scratchpad:
#
    # Sway has a "scratchpad", which is a bag of holding for windows.
    # You can send windows there and get them back later.

    # Move the currently focused window to the scratchpad
    bindsym $mod+Shift+minus move scratchpad

    # Show the next scratchpad window or hide the focused scratchpad window.
    # If there are multiple scratchpad windows, this command cycles through them.
    bindsym $mod+minus scratchpad show
#
# Resizing containers:
#
mode "resize" {
    # left will shrink the containers width
    # right will grow the containers width
    # up will shrink the containers height
    # down will grow the containers height
    bindsym $left resize shrink width 10px
    bindsym $down resize grow height 10px
    bindsym $up resize shrink height 10px
    bindsym $right resize grow width 10px

    # Ditto, with arrow keys
    bindsym Left resize shrink width 10px
    bindsym Down resize grow height 10px
    bindsym Up resize shrink height 10px
    bindsym Right resize grow width 10px

    # Return to default mode
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

set $mode_system (l) lock, (e) logout, (s) suspend, (r) reboot, (S) shutdown, (R) UEFI
mode "$mode_system" {
    bindsym l exec $lock, mode "default"
    bindsym e exit
    bindsym s exec --no-startup-id systemctl suspend, mode "default"
    bindsym r exec --no-startup-id systemctl reboot, mode "default"
    bindsym Shift+s exec --no-startup-id systemctl poweroff -i, mode "default"
    bindsym Shift+r exec --no-startup-id systemctl reboot --firmware-setup, mode "default"

    # return to default mode
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+Shift+e mode "$mode_system"
#
# Media:
#
    bindsym $mod+m exec pactl set-source-mute @DEFAULT_SOURCE@ false
    bindsym --release $mod+m exec pactl set-source-mute @DEFAULT_SOURCE@ true
    bindsym $mod+Shift+m exec pactl set-source-mute @DEFAULT_SOURCE@ toggle

    bindsym $mod+Shift+v exec pactl set-sink-mute @DEFAULT_SINK@ toggle

    bindsym $mod+Mod1+1 exec pactl set-sink-volume @DEFAULT_SINK@ 10%
    bindsym $mod+Mod1+2 exec pactl set-sink-volume @DEFAULT_SINK@ 20%
    bindsym $mod+Mod1+3 exec pactl set-sink-volume @DEFAULT_SINK@ 30%
    bindsym $mod+Mod1+4 exec pactl set-sink-volume @DEFAULT_SINK@ 40%
    bindsym $mod+Mod1+5 exec pactl set-sink-volume @DEFAULT_SINK@ 50%
    bindsym $mod+Mod1+6 exec pactl set-sink-volume @DEFAULT_SINK@ 60%
    bindsym $mod+Mod1+7 exec pactl set-sink-volume @DEFAULT_SINK@ 70%
    bindsym $mod+Mod1+8 exec pactl set-sink-volume @DEFAULT_SINK@ 80%
    bindsym $mod+Mod1+9 exec pactl set-sink-volume @DEFAULT_SINK@ 90%
    bindsym $mod+Mod1+0 exec pactl set-sink-volume @DEFAULT_SINK@ 100%


    # Volume
    bindsym XF86AudioRaiseVolume exec $scripts/modify-volume.sh "+"
    bindsym XF86AudioLowerVolume exec $scripts/modify-volume.sh "-"
    bindsym XF86AudioMute exec pactl set-sink-mute @DEFAULT_SINK@ toggle
    bindsym XF86AudioMicMute exec pactl set-source-mute @DEFAULT_SOURCE@ toggle

    # Media navigation
    bindsym XF86AudioPlay exec playerctl play-pause
    bindsym XF86AudioNext exec playerctl next
    bindsym XF86AudioPrev exec playerctl previous
    bindsym XF86Search exec $menu
#
# Display:
#
    bindsym XF86MonBrightnessDown exec brightnessctl set 5%-
    bindsym XF86MonBrightnessUp exec brightnessctl set 5%+
    bindsym XF86ScreenSaver exec $lock
    bindcode 160 exec $lock
#
# Status Bar:
#
# Read `man 5 sway-bar` for more information about this section.
# bar {
#     swaybar_command waybar
#    #position bottom
#    #mode hide
#
#    # When the status_command prints a new line to stdout, swaybar updates.
#    # The default just shows the current date and time.
#    status_command while ~/.config/sway/status.sh; do sleep 1; done
#    colors {
#        statusline $text
#        background $highlightlow
#        focused_workspace $highlighthigh $highlighthigh $text
#        inactive_workspace $highlightlow $highlightlow #5c5c5c
#        urgent_workspace $love $love $text
#    }
# }
exec test -x $scripts/start-waybar.sh && $scripts/start-waybar.sh || waybar

include /etc/sway/config.d/*

#
# Autostart programs:
#
exec $tmux
exec $browser
exec --no-startup-id gammastep -m wayland
exec --no-startup-id autotiling
exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ true

# Private/local overrides (e.g. HA bindings, secrets-dependent config)
include $HOME/.config/sway/local.config

# Device specific configuration and overrides
include $HOME/.config/sway/device.config
workspace 1
