{
  "ghostty": {
    "type": "direct",
    "key": "terminal_palette",
    "target": "~/.config/ghostty/themes/color256-theme",
    "reload": "~/.config/thememanager/reload-ghostty.sh"
  },
  "sway": {
    "type": "template",
    "source": "~/.config/thememanager/templates/sway/theme.config.tmpl",
    "target": "~/.config/sway/theme.config",
    "reload": "swaymsg reload"
  },
  "waybar": {
    "type": "template",
    "source": "~/.config/thememanager/templates/waybar/style.css.tmpl",
    "target": "~/.config/waybar/style.css"
  },
  "swaylock": {
    "type": "template",
    "source": "~/.config/thememanager/templates/swaylock/config.tmpl",
    "target": "~/.config/swaylock/config"
  },
  "mako": {
    "type": "template",
    "source": "~/.config/thememanager/templates/mako/theme.ini.tmpl",
    "target": "~/.config/mako/theme.ini",
    "reload": "makoctl reload"
  }
}
