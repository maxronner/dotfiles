#!/usr/bin/env bash
set -euo pipefail

WALLPAPER_DIR="${WALLPAPER_DIR:-$HOME/.local/share/wallpapers}"
WALLPAPER_PATH="${WALLPAPER_PATH:-$HOME/.local/share/wallpaper/current}"
need_cmd() { command -v "$1" >/dev/null 2>&1 || {
  echo "$1 is required but not installed." >&2
  exit 1
}; }
need_cmd shuf

EXTENSIONS=(jpg jpeg png gif bmp)

pick_random() {
  if command -v fd >/dev/null 2>&1; then
    fd_args=()
    for ext in "${EXTENSIONS[@]}"; do
      fd_args+=(-e "$ext")
    done
    fd "${fd_args[@]}" -d 1 . "$WALLPAPER_DIR" | shuf -n 1
  else
    find_expr=()
    for ext in "${EXTENSIONS[@]}"; do
      find_expr+=(-iname "*.$ext" -o)
    done
    unset 'find_expr[-1]'
    find "$WALLPAPER_DIR" -maxdepth 1 -type f \( "${find_expr[@]}" \) | shuf -n 1
  fi
}

resolve_input() {
  local arg="$1"

  [[ -z "$arg" ]] && return 1

  if [[ -f "$arg" ]]; then
    printf '%s\n' "$(realpath "$arg")"
    return 0
  fi

  if [[ -f "$WALLPAPER_DIR/$arg" ]]; then
    printf '%s\n' "$(realpath "$WALLPAPER_DIR/$arg")"
    return 0
  fi

  return 1
}

mode="commit"
selected="${WALLPAPER_IMAGE:-}"

usage() {
  cat >&2 <<'EOF'
Usage: wl-set-wallpaper [--commit|--preview] [wallpaper]

--commit   Persist wallpaper and run commit side effects: auto palette + reloads (default)
--preview  Persist wallpaper for visual preview only; skip auto palette regeneration
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --commit) mode="commit" ;;
    --preview) mode="preview" ;;
    -h|--help) usage; exit 0 ;;
    --) shift; selected="${1-}"; break ;;
    -*) echo "Unknown option: $1" >&2; usage; exit 2 ;;
    *) selected="$1" ;;
  esac
  shift
done

if [[ -n "$selected" ]]; then
  requested="$selected"
  if ! selected="$(resolve_input "$requested")"; then
    echo "Wallpaper not found: $requested" >&2
    exit 1
  fi
else
  selected="$(pick_random)"
fi

if [[ -z "$selected" ]]; then
  echo "No wallpapers found in $WALLPAPER_DIR" >&2
  exit 1
fi

mkdir -p "$(dirname "$WALLPAPER_PATH")"
current=""
if [[ -L "$WALLPAPER_PATH" ]]; then
  current="$(readlink "$WALLPAPER_PATH")"
fi

if [[ "$current" != "$selected" ]]; then
  rm -f "$WALLPAPER_PATH"
  ln -s "$selected" "$WALLPAPER_PATH"
fi

if [[ "$mode" == "commit" ]] && command -v thememanager >/dev/null 2>&1; then
  thememanager auto --wallpaper "$selected" || true
fi

# Always signal quickshell to pick up the new wallpaper path
if command -v quickshell >/dev/null 2>&1; then
  quickshell msg wallpaper reload 2>/dev/null || true
fi
